# ============================================================================
# PRODUCTION .env — copy to .env on your server and fill in real values
# ============================================================================

APP_NAME="Vehicle Battery Store"
APP_ENV=production
APP_DEBUG=false
APP_KEY=                                # run: php artisan key:generate
APP_URL=https://yourdomain.com
APP_TIMEZONE=Asia/Kolkata
APP_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=error                         # warning|error|critical in prod

# --- Database (MySQL in production) -----------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vehicle_battery_store
DB_USERNAME=vbs_app                     # dedicated user, NOT root
DB_PASSWORD=                            # strong password

# --- Session / Cache / Queue -----------------------------------------------
# database is fine for small scale. Redis recommended once you scale.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true              # HTTPS only — REQUIRED for prod
SESSION_SAME_SITE=lax

CACHE_STORE=database
QUEUE_CONNECTION=database

# --- Redis (optional but recommended) --------------------------------------
# Uncomment + switch SESSION_DRIVER, CACHE_STORE, QUEUE_CONNECTION to "redis"
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# --- File storage ----------------------------------------------------------
FILESYSTEM_DISK=public

# --- Mail (REQUIRED — used for OTP, order confirmation, password reset) ----
# Pick ONE provider and fill in. Examples below.
MAIL_MAILER=smtp
MAIL_HOST=smtp.yourprovider.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=orders@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"

# Common providers (use one of these for MAIL_HOST):
# - Gmail:    smtp.gmail.com (port 587, tls, app-password)
# - Postmark: smtp.postmarkapp.com (use Postmark token as username + password)
# - SES:      email-smtp.ap-south-1.amazonaws.com (your SMTP creds)
# - SendGrid: smtp.sendgrid.net (username = "apikey", password = your API key)
# - Resend:   smtp.resend.com (port 587)
# - Brevo:    smtp-relay.brevo.com (port 587)

# --- Razorpay (for online payments) ----------------------------------------
RAZORPAY_KEY=
RAZORPAY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Stripe (optional, if you accept international cards) ------------------
# STRIPE_KEY=
# STRIPE_SECRET=
# STRIPE_WEBHOOK_SECRET=

# --- SMS gateway (optional) ------------------------------------------------
# Currently LogSmsGateway logs to disk. Switch to a real provider:
SMS_GATEWAY=log                         # change to: msg91 | twilio | gupshup
# MSG91_AUTHKEY=
# MSG91_SENDER=VBSTOR
# MSG91_TEMPLATE_OTP=

# --- WhatsApp gateway (optional) -------------------------------------------
WHATSAPP_GATEWAY=log                    # change to: meta | gupshup

# --- Trusted proxies (if behind Cloudflare/load balancer) ------------------
# TRUSTED_PROXIES=*

# --- Security --------------------------------------------------------------
BCRYPT_ROUNDS=12
SANCTUM_STATEFUL_DOMAINS=yourdomain.com,www.yourdomain.com
